---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { fetchDlsiteWork } from '../lib/dlsite';

interface ModelInfo {
	name: string;
	trigger?: string;
	notes?: string;
}

interface Props {
	dlsiteId?: string;
	dlsiteUrl?: string;
	danbooruTags?: string[];
	prompt?: string;
	images?: ImageMetadata[];
	models?: ModelInfo;
	title?: string;
}

const {
	dlsiteId,
	dlsiteUrl,
	danbooruTags = [],
	prompt,
	images = [],
	models,
	title = '',
} = Astro.props;

const dlsite = dlsiteId
	? await fetchDlsiteWork(dlsiteId, dlsiteUrl)
	: null;
const dlsiteHref = dlsite?.workUrl ?? dlsiteUrl;
const showDlsite = Boolean(dlsite || dlsiteHref);
const showModels = Boolean(models?.name);
const showPrompt = Boolean(prompt?.trim());

const hasAnything =
	showDlsite ||
	danbooruTags.length > 0 ||
	showPrompt ||
	images.length > 0 ||
	showModels;

const galleryItems =
	images.length > 0
		? await Promise.all(
				images.map(async (img, i) => ({
					img,
					alt: `${title || 'サンプル'} ${i + 1}`,
					// compile 時は img.src（ベースパス）が dist に存在しないため getImage で実 URL を取得
					previewSrc: (await getImage({ src: img })).src,
					stripSrc: (await getImage({ src: img, width: 128 })).src,
					index: i,
				})),
			)
		: [];

const keyTagsText = danbooruTags.join(', ');
const galleryId = `a1111-gallery-${Math.random().toString(36).slice(2, 9)}`;
const genrePreview = dlsite?.genres.slice(0, 6) ?? [];
const priceLabel =
	dlsite?.price != null
		? `¥${dlsite.price.toLocaleString('ja-JP')}`
		: null;
const modelHref = models?.name
	? `/models/${encodeURIComponent(models.name)}/`
	: null;
---

{
	hasAnything && (
		<section class="trend" aria-label="トレンド逆引きパネル">
			{/* 画像 → 生呪文 → キータグ → モデル → DLsite */}
			{images.length > 0 && (
				<div class="gallery-box" data-a1111-gallery={galleryId}>
					<h3 class="box-title">
						🖼 ローカル錬成サンプル（{images.length}枚）
						<span class="gallery-hint">
							クリックで拡大 / ←→で送り / Ctrl+ホイールで拡大縮小
						</span>
					</h3>
					<ul class="gallery">
						{galleryItems.map(({ img, alt, previewSrc, index }) => (
							<li>
								<button
									type="button"
									class="gallery-thumb"
									data-index={index}
									data-src={previewSrc}
									data-alt={alt}
									aria-label={`画像 ${index + 1} を拡大表示`}
								>
									<Image
										src={img}
										alt={alt}
										widths={[320, 640]}
										sizes="(max-width: 720px) 50vw, 280px"
									/>
								</button>
							</li>
						))}
					</ul>

					{/* A1111風ライトボックス */}
					<dialog class="lb" data-lightbox aria-label="生成画像プレビュー">
						<div class="lb-chrome">
							<p class="lb-counter" data-lb-counter>
								1 / {images.length}
							</p>
							<div class="lb-zoom-ui" aria-label="拡大縮小">
								<button type="button" class="lb-zoom-btn" data-lb-zoom-out aria-label="縮小">
									−
								</button>
								<button
									type="button"
									class="lb-zoom-label"
									data-lb-zoom-reset
									title="100%に戻す"
								>
									100%
								</button>
								<button type="button" class="lb-zoom-btn" data-lb-zoom-in aria-label="拡大">
									＋
								</button>
							</div>
							{/* method=dialog でブラウザ標準の閉じるも併用 */}
							<form method="dialog" class="lb-close-form">
								<button type="submit" class="lb-close" data-lb-close aria-label="閉じる">
									✕
								</button>
							</form>
						</div>
						<div class="lb-body">
							<button
								type="button"
								class="lb-nav prev"
								data-lb-prev
								aria-label="前の画像"
							>
								‹
							</button>
							<figure class="lb-stage" data-lb-stage>
								<img data-lb-img alt="" draggable="false" />
							</figure>
							<button
								type="button"
								class="lb-nav next"
								data-lb-next
								aria-label="次の画像"
							>
								›
							</button>
						</div>
						<ul class="lb-strip" data-lb-strip>
							{galleryItems.map(({ stripSrc, alt, index }) => (
								<li>
									<button
										type="button"
										class="lb-strip-btn"
										data-strip-index={index}
										aria-label={`画像 ${index + 1}`}
									>
										<img src={stripSrc} alt="" loading="lazy" />
									</button>
								</li>
							))}
						</ul>
					</dialog>
				</div>
			)}

			{showPrompt && (
				<div class="prompt-box">
					<h3 class="box-title">🔮 実際に使った生呪文（Danbooruプロンプト）</h3>
					<div class="copy-box">
						<p class="copy-label">コピペ用</p>
						<pre><code>{prompt}</code></pre>
					</div>
				</div>
			)}

			{danbooruTags.length > 0 && (
				<div class="tags-box">
					<h3 class="box-title">🔑 キータグ（WD14抽出）</h3>
					<ul class="tag-list">
						{danbooruTags.map((tag) => (
							<li>
								<code>{tag}</code>
							</li>
						))}
					</ul>
					{keyTagsText && (
						<div class="copy-box">
							<p class="copy-label">コピペ用（キータグ）</p>
							<pre><code>{keyTagsText}</code></pre>
						</div>
					)}
				</div>
			)}

			{showModels && models && (
				<div class="models-box">
					<h3 class="box-title">🪄 使用モデル</h3>
					<p class="model-name">
						{modelHref ? (
							<a class="model-link" href={modelHref}>
								{models.name}
							</a>
						) : (
							models.name
						)}
					</p>
					{models.trigger && (
						<div class="copy-box">
							<p class="copy-label">トリガー／品質ワード</p>
							<pre><code>{models.trigger}</code></pre>
						</div>
					)}
					{models.notes && <p class="model-notes">{models.notes}</p>}
				</div>
			)}

			{showDlsite && (
				<div class="dlsite-box">
					<p class="dlsite-label">- 元ネタ / DLsite -</p>
					{dlsite ? (
						<a
							class="dlsite-card"
							href={dlsite.workUrl}
							target="_blank"
							rel="noopener nofollow sponsored"
						>
							{dlsite.thumbUrl && (
								<img
									class="dlsite-thumb"
									src={dlsite.thumbUrl}
									alt=""
									width={160}
									height={120}
									loading="lazy"
									decoding="async"
									referrerpolicy="no-referrer"
								/>
							)}
							<div class="dlsite-meta">
								<p class="dlsite-title">{dlsite.title}</p>
								{dlsite.maker && <p class="dlsite-maker">{dlsite.maker}</p>}
								{(priceLabel || dlsite.workno) && (
									<p class="dlsite-sub">
										{priceLabel && <span class="dlsite-price">{priceLabel}</span>}
										<span class="dlsite-id">{dlsite.workno}</span>
									</p>
								)}
								{genrePreview.length > 0 && (
									<ul class="dlsite-genres">
										{genrePreview.map((g) => (
											<li>{g}</li>
										))}
									</ul>
								)}
								{dlsite.intro && <p class="dlsite-intro">{dlsite.intro}</p>}
								<span class="dlsite-cta">DLsite で見る »</span>
							</div>
						</a>
					) : (
						<>
							<a
								class="dlsite-link"
								href={dlsiteHref}
								target="_blank"
								rel="noopener nofollow sponsored"
							>
								{dlsiteId ? `${dlsiteId} を見に行く »` : '作品ページを開く »'}
							</a>
							{dlsiteId && <p class="dlsite-id">product_id: {dlsiteId}</p>}
						</>
					)}
				</div>
			)}
		</section>
	)
}

<script>
	function initGallery(root: HTMLElement) {
		const dialog = root.querySelector<HTMLDialogElement>('[data-lightbox]');
		const imgEl = root.querySelector<HTMLImageElement>('[data-lb-img]');
		const stage = root.querySelector<HTMLElement>('[data-lb-stage]');
		const counter = root.querySelector<HTMLElement>('[data-lb-counter]');
		const zoomLabel = root.querySelector<HTMLElement>('[data-lb-zoom-reset]');
		const thumbs = Array.from(
			root.querySelectorAll<HTMLButtonElement>('.gallery-thumb'),
		);
		const stripBtns = Array.from(
			root.querySelectorAll<HTMLButtonElement>('[data-strip-index]'),
		);
		if (!dialog || !imgEl || !stage || thumbs.length === 0) return;

		const items = thumbs.map((t) => {
			const thumbImg = t.querySelector('img');
			return {
				src:
					t.dataset.src ||
					thumbImg?.currentSrc ||
					thumbImg?.src ||
					'',
				alt: t.dataset.alt ?? '',
			};
		});
		let index = 0;
		let scale = 1;
		let tx = 0;
		let ty = 0;
		let dragging = false;
		let dragX = 0;
		let dragY = 0;
		const MIN = 0.5;
		const MAX = 5;
		const STEP = 0.25;

		function applyTransform() {
			imgEl!.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
			stage!.classList.toggle('is-zoomed', scale > 1.01);
			if (zoomLabel) zoomLabel.textContent = `${Math.round(scale * 100)}%`;
		}

		function setZoom(next: number, originX?: number, originY?: number) {
			const prev = scale;
			scale = Math.min(MAX, Math.max(MIN, next));
			if (scale <= 1) {
				scale = 1;
				tx = 0;
				ty = 0;
			} else if (originX != null && originY != null && prev > 0) {
				// カーソル位置を基準にズーム（ざっくり）
				const rect = stage!.getBoundingClientRect();
				const cx = originX - rect.left - rect.width / 2;
				const cy = originY - rect.top - rect.height / 2;
				const ratio = scale / prev;
				tx = cx - (cx - tx) * ratio;
				ty = cy - (cy - ty) * ratio;
			}
			applyTransform();
		}

		function resetZoom() {
			scale = 1;
			tx = 0;
			ty = 0;
			applyTransform();
		}

		function show(i: number) {
			index = (i + items.length) % items.length;
			const item = items[index];
			imgEl!.src = item.src;
			imgEl!.alt = item.alt;
			if (counter) counter.textContent = `${index + 1} / ${items.length}`;
			stripBtns.forEach((b, bi) => {
				b.classList.toggle('is-active', bi === index);
			});
			resetZoom();
		}

		function open(i: number) {
			show(i);
			if (!dialog!.open) dialog!.showModal();
			document.documentElement.classList.add('lb-open');
		}

		function close() {
			dialog!.close();
			document.documentElement.classList.remove('lb-open');
			resetZoom();
		}

		thumbs.forEach((t) => {
			t.addEventListener('click', () => open(Number(t.dataset.index ?? 0)));
		});
		stripBtns.forEach((b) => {
			b.addEventListener('click', () => show(Number(b.dataset.stripIndex ?? 0)));
		});
		dialog.querySelector('[data-lb-prev]')?.addEventListener('click', () =>
			show(index - 1),
		);
		dialog.querySelector('[data-lb-next]')?.addEventListener('click', () =>
			show(index + 1),
		);
		dialog.querySelector('[data-lb-zoom-in]')?.addEventListener('click', () =>
			setZoom(scale + STEP),
		);
		dialog.querySelector('[data-lb-zoom-out]')?.addEventListener('click', () =>
			setZoom(scale - STEP),
		);
		dialog.querySelector('[data-lb-zoom-reset]')?.addEventListener('click', resetZoom);

		// 閉じる（✕ / Esc / form method=dialog / 背景クリック）
		dialog.querySelector('[data-lb-close]')?.addEventListener('click', (e) => {
			e.preventDefault();
			e.stopPropagation();
			close();
		});
		dialog.addEventListener('cancel', (e) => {
			// Esc
			e.preventDefault();
			close();
		});
		dialog.addEventListener('close', () => {
			document.documentElement.classList.remove('lb-open');
			resetZoom();
		});
		dialog.addEventListener('click', (e) => {
			const target = e.target as HTMLElement | null;
			if (!target) return;
			if (target.closest('[data-lb-close]')) {
				e.preventDefault();
				e.stopPropagation();
				close();
				return;
			}
			// backdrop 相当（dialog 自体をクリック）
			if (target === dialog) close();
		});

		// Ctrl + ホイールで拡大縮小
		dialog.addEventListener(
			'wheel',
			(e) => {
				if (!dialog.open || !e.ctrlKey) return;
				e.preventDefault();
				const delta = e.deltaY > 0 ? -STEP : STEP;
				setZoom(scale + delta, e.clientX, e.clientY);
			},
			{ passive: false },
		);

		// 拡大中はドラッグでパン
		stage.addEventListener('pointerdown', (e) => {
			if (scale <= 1) return;
			dragging = true;
			dragX = e.clientX - tx;
			dragY = e.clientY - ty;
			stage.setPointerCapture(e.pointerId);
			stage.classList.add('is-panning');
		});
		stage.addEventListener('pointermove', (e) => {
			if (!dragging) return;
			tx = e.clientX - dragX;
			ty = e.clientY - dragY;
			applyTransform();
		});
		const endPan = (e: PointerEvent) => {
			if (!dragging) return;
			dragging = false;
			stage.classList.remove('is-panning');
			try {
				stage.releasePointerCapture(e.pointerId);
			} catch {
				/* ignore */
			}
		};
		stage.addEventListener('pointerup', endPan);
		stage.addEventListener('pointercancel', endPan);

		dialog.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') {
				e.preventDefault();
				close();
				return;
			}
			if (e.key === 'ArrowLeft') {
				e.preventDefault();
				show(index - 1);
			} else if (e.key === 'ArrowRight') {
				e.preventDefault();
				show(index + 1);
			} else if (e.key === '+' || e.key === '=') {
				e.preventDefault();
				setZoom(scale + STEP);
			} else if (e.key === '-' || e.key === '_') {
				e.preventDefault();
				setZoom(scale - STEP);
			} else if (e.key === '0') {
				e.preventDefault();
				resetZoom();
			}
		});
	}

	document
		.querySelectorAll<HTMLElement>('[data-a1111-gallery]')
		.forEach(initGallery);
</script>

<style>
	.trend {
		margin: 1.6em 0 0.4em;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}
	.dlsite-box,
	.tags-box,
	.gallery-box,
	.models-box,
	.prompt-box {
		background: var(--surface-2);
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 14px 16px;
	}
	.model-name {
		margin: 0 0 10px;
		font-size: 1.05rem;
		font-weight: 800;
		line-height: 1.4;
		color: var(--text-strong);
	}
	.model-link {
		color: var(--text-strong);
		text-decoration: none;
	}
	.model-link:hover {
		color: var(--accent);
		text-decoration: underline;
	}
	.model-notes {
		margin: 10px 0 0;
		font-size: 0.88rem;
		line-height: 1.55;
		color: var(--muted);
	}
	.dlsite-label,
	.copy-label {
		margin: 0 0 6px;
		font-size: 0.7rem;
		letter-spacing: 0.12em;
		color: var(--muted);
		font-weight: 700;
	}
	.dlsite-card {
		display: grid;
		grid-template-columns: 140px 1fr;
		gap: 14px;
		align-items: start;
		color: inherit;
		text-decoration: none;
		border-radius: 6px;
		padding: 4px;
		margin: 0 -4px;
		transition: background 0.15s ease;
	}
	.dlsite-card:hover {
		background: var(--surface);
		text-decoration: none;
	}
	.dlsite-thumb {
		display: block;
		width: 140px;
		height: auto;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border-radius: 4px;
		border: 1px solid var(--border);
		background: var(--surface);
	}
	.dlsite-meta {
		min-width: 0;
	}
	.dlsite-title {
		margin: 0 0 4px;
		font-size: 1.05rem;
		font-weight: 800;
		line-height: 1.4;
		color: var(--text-strong);
	}
	.dlsite-card:hover .dlsite-title {
		color: var(--accent);
	}
	.dlsite-maker {
		margin: 0 0 6px;
		font-size: 0.85rem;
		color: var(--muted);
	}
	.dlsite-sub {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 12px;
		align-items: baseline;
		margin: 0 0 8px;
		font-size: 0.8rem;
	}
	.dlsite-price {
		font-weight: 800;
		color: var(--accent);
	}
	.dlsite-id {
		margin: 6px 0 0;
		font-size: 0.75rem;
		color: var(--muted);
		font-variant-numeric: tabular-nums;
	}
	.dlsite-sub .dlsite-id {
		margin: 0;
	}
	.dlsite-genres {
		list-style: none;
		margin: 0 0 8px;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}
	.dlsite-genres li {
		font-size: 0.72rem;
		font-weight: 700;
		color: var(--muted);
		border: 1px solid var(--border);
		border-radius: 4px;
		padding: 2px 8px;
		background: var(--surface);
	}
	.dlsite-intro {
		margin: 0 0 8px;
		font-size: 0.82rem;
		line-height: 1.55;
		color: var(--text);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.dlsite-cta {
		display: inline-block;
		font-size: 0.85rem;
		font-weight: 800;
		color: var(--accent);
	}
	.dlsite-link {
		display: inline-block;
		font-weight: 800;
		font-size: 0.95rem;
		color: var(--accent);
	}
	@media (max-width: 520px) {
		.dlsite-card {
			grid-template-columns: 1fr;
		}
		.dlsite-thumb {
			width: 100%;
			max-width: 280px;
		}
	}
	.box-title {
		margin: 0 0 10px;
		font-size: 1rem;
		font-weight: 800;
		color: var(--text-strong);
	}
	.gallery-hint {
		display: block;
		margin-top: 4px;
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--muted);
		letter-spacing: 0;
	}
	.tag-list {
		list-style: none;
		margin: 0 0 12px;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}
	.tag-list code {
		display: inline-block;
		font-size: 0.8rem;
		color: var(--accent);
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 3px 10px;
	}
	.copy-box pre {
		margin: 0;
		padding: 12px;
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 6px;
		overflow-x: auto;
		white-space: pre-wrap;
		word-break: break-all;
		font-size: 0.82rem;
		line-height: 1.6;
		color: var(--text);
	}

	/* サムネグリッド（A1111のギャラリー枠） */
	.gallery {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 10px;
	}
	.gallery-thumb {
		display: block;
		width: 100%;
		padding: 0;
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
		background: var(--bg);
		cursor: zoom-in;
		font: inherit;
	}
	.gallery-thumb:hover {
		border-color: var(--accent);
	}
	.gallery-thumb:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
	/* 枠の縦横比は固定しない → 画像の自然な比率で全体表示 */
	.gallery-thumb :global(img) {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 0;
		pointer-events: none;
	}

	/* A1111風ライトボックス：画面内に画像全体が収まる
	   ※ dialog に display:flex を常時当てると、close 後も表示が残るので [open] のときだけ */
	.lb {
		width: min(100vw - 16px, 1400px);
		height: min(100dvh - 16px, 100vh - 16px);
		max-width: none;
		max-height: none;
		margin: auto;
