---
import { Image } from 'astro:assets';
import charaIcon from '../assets/brand/chara.webp';
import { BSKY_HANDLE, BSKY_HASHTAG, BSKY_URL, SITE_TITLE } from '../consts';

interface Props {
	title?: string;
}

const { title } = Astro.props;

// 記事タイトル付きの投稿用テキストを用意（プランC・Bluesky中心）
const shareText = title
	? `「${title}」読んだわよ！ ${BSKY_HASHTAG}`
	: `${SITE_TITLE}見てるわ！ ${BSKY_HASHTAG}`;
const replyHref = `https://bsky.app/intent/compose?text=${encodeURIComponent(shareText)}`;
---

<section class="bsky-reply" aria-label="コメント（Blueskyへの返信）">
	<div class="bsky-reply-head">
		<Image
			class="br-ico"
			src={charaIcon}
			alt="賀田野リナ"
			width={80}
			height={80}
			densities={[1, 2]}
		/>
		<p class="br-lead">今夜の黒ミサについて言いたいことがある魔法使いへ</p>
	</div>
	<p class="br-body">
		このブログにコメント欄は無いわ。感想も文句も、
		<strong>{BSKY_HASHTAG}</strong> を付けて Bluesky で私に直接送りなさいよね！
		勝手にタグを付けて盛り上がってくれたら、私が拡散の魔法をかけてあげる。
	</p>
	<div class="br-actions">
		<a class="br-btn primary" href={replyHref} target="_blank" rel="noopener">
			Bluesky でこの記事に投稿する
		</a>
		<a class="br-btn ghost" href={BSKY_URL} target="_blank" rel="noopener">
			{BSKY_HANDLE} をフォロー
		</a>
	</div>
</section>

<style>
	.bsky-reply {
		background: var(--surface);
		border: 1px solid var(--border);
		border-left: 3px solid var(--pink);
		color: var(--text);
		border-radius: 0 8px 8px 0;
		padding: 20px;
		margin: 32px 0 8px;
	}
	.bsky-reply-head {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 8px;
	}
	.br-ico {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		object-fit: cover;
		background: var(--icon-bg);
		border: 1px solid var(--border);
		flex-shrink: 0;
	}
	.br-lead {
		margin: 0;
		font-weight: 700;
		font-size: 1rem;
		color: var(--text-strong);
	}
	.br-body {
		margin: 0 0 16px;
		font-size: 0.9rem;
		line-height: 1.8;
		color: var(--text);
	}
	.br-body strong {
		color: var(--pink);
	}
	.br-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}
	.br-btn {
		display: inline-block;
		font-weight: 700;
		font-size: 0.85rem;
		padding: 10px 20px;
		border-radius: 6px;
	}
	.br-btn.primary {
		color: var(--text-strong);
		background: var(--accent-dim);
	}
	.br-btn.primary:hover {
		background: var(--accent);
	}
	.br-btn.ghost {
		color: var(--text);
		border: 1px solid var(--border);
	}
	.br-btn.ghost:hover {
		border-color: var(--accent);
		color: var(--text-strong);
	}
	.br-btn:hover {
		text-decoration: none;
	}
</style>
