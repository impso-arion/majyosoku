---
import { Image } from 'astro:assets';
import brandIcon from '../assets/brand/icon.webp';
import { SITE_CATCH, SITE_READING, SITE_TITLE, X_URL } from '../consts';
import AgeGate from './AgeGate.astro';
import HeaderLink from './HeaderLink.astro';
---

<AgeGate />
<header class="site-header">
	<div class="wrap header-inner">
		<a class="brand" href="/">
			<Image
				class="brand-mark"
				src={brandIcon}
				alt={SITE_TITLE}
				width={96}
				height={96}
				densities={[1, 2]}
			/>
			<span class="brand-text">
				<span class="brand-title">{SITE_TITLE}</span>
				<span class="brand-reading">{SITE_READING}</span>
			</span>
			<span class="brand-catch">{SITE_CATCH}</span>
		</a>
	</div>
	<nav class="site-nav">
		<div class="wrap nav-inner">
			<HeaderLink href="/">TOP</HeaderLink>
			<HeaderLink href="/blog">記事一覧</HeaderLink>
			<HeaderLink href="/tags">タグ検索</HeaderLink>
			<HeaderLink href="/about">運営者</HeaderLink>
			<a class="nav-x" href={X_URL} target="_blank" rel="noopener">𝕏 でリプする</a>
		</div>
	</nav>
</header>

<style>
	.site-header {
		background: var(--bg-deep);
		border-bottom: 1px solid var(--border);
	}
	.header-inner {
		display: flex;
		align-items: center;
		padding: 16px 0 14px;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 12px;
		color: var(--text-strong);
	}
	.brand:hover {
		text-decoration: none;
	}
	.brand-mark {
		width: 56px;
		height: 56px;
		border-radius: 12px;
		object-fit: cover;
		flex-shrink: 0;
		background: var(--icon-bg);
	}
	.brand-text {
		display: flex;
		flex-direction: column;
		line-height: 1.25;
		min-width: 0;
	}
	.brand-title {
		font-size: 1.35rem;
		font-weight: 800;
		letter-spacing: 0.02em;
		color: var(--text-strong);
	}
	.brand-reading {
		font-size: 0.65rem;
		letter-spacing: 0.06em;
		color: var(--muted);
	}
	.brand-catch {
		margin-left: 14px;
		padding: 3px 12px;
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--accent);
		border: 1px solid var(--accent-dim);
		border-radius: 999px;
		flex-shrink: 0;
	}

	.site-nav {
		background: var(--surface);
		border-top: 1px solid var(--border);
	}
	.nav-inner {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 2px;
	}
	.site-nav :global(a) {
		display: inline-block;
		padding: 10px 12px;
		font-size: 0.82rem;
		font-weight: 700;
		color: var(--text);
		border-bottom: 3px solid transparent;
	}
	.site-nav :global(a:hover) {
		color: var(--text-strong);
		background: var(--surface-2);
		text-decoration: none;
	}
	.site-nav :global(a.active) {
		color: var(--text-strong);
		border-bottom-color: var(--accent);
		text-decoration: none;
	}
	.nav-x {
		margin-left: auto;
		color: var(--accent) !important;
	}

	@media (max-width: 720px) {
		.brand-catch {
			display: none;
		}
		.brand-reading {
			display: none;
		}
		.brand-title {
			font-size: 1.05rem;
		}
		.nav-x {
			margin-left: 0;
		}
	}
</style>
