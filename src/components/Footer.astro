---
import { Image } from 'astro:assets';
import footerIcon from '../assets/brand/footer.webp';
import { BSKY_HANDLE, BSKY_URL, SITE_SUBTITLE, SITE_TITLE } from '../consts';
const today = new Date();
---

<footer class="site-footer">
	<div class="wrap footer-inner">
		<div class="footer-brand">
			<span class="fb-title">
				<Image
					class="fb-icon"
					src={footerIcon}
					alt=""
					width={80}
					height={80}
					densities={[1, 2]}
				/>
				{SITE_TITLE}
			</span>
			<span class="fb-sub">{SITE_SUBTITLE}</span>
		</div>

		<nav class="footer-links" aria-label="フッターナビ">
			<a href="/">TOP</a>
			<a href="/blog">記事一覧</a>
			<a href="/categories">カテゴリ検索</a>
			<a href="/models">モデル検索</a>
			<a href="/tags">タグ検索</a>
			<a href="/about">運営者情報</a>
			<a href={BSKY_URL} target="_blank" rel="noopener">Bluesky {BSKY_HANDLE}</a>
		</nav>

		<p class="footer-note">
			当サイトはアフィリエイト広告（成果報酬型広告）を利用しています。掲載情報は執筆時点のものであり、正確性・最新性を保証するものではありません。
		</p>
		<p class="footer-r18">
			本サイトには成人向けの話題を含みます。18歳未満の方の閲覧はご遠慮ください。ご意見・ご感想は Bluesky
			<a href={BSKY_URL} target="_blank" rel="noopener">{BSKY_HANDLE}</a> までどうぞ。
		</p>

		<p class="copyright">
			&copy; {today.getFullYear()} {SITE_TITLE} All rights reserved.
		</p>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: 20px;
		background: var(--bg-deep);
		border-top: 1px solid var(--border);
		color: var(--text);
	}
	.footer-inner {
		padding: 28px 0 40px;
		text-align: center;
	}
	.footer-brand {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		margin-bottom: 14px;
	}
	.fb-title {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		font-size: 1.15rem;
		font-weight: 800;
		color: var(--text-strong);
		line-height: 1.3;
	}
	.fb-icon {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		object-fit: cover;
		background: var(--icon-bg);
		border: 1px solid var(--border);
		flex-shrink: 0;
	}
	.fb-sub {
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		color: var(--muted);
	}
	.footer-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 8px 18px;
		margin-bottom: 16px;
	}
	.footer-links a {
		color: var(--text);
		font-size: 0.85rem;
		font-weight: 700;
	}
	.footer-links a:hover {
		color: var(--accent);
	}
	.footer-note,
	.footer-r18 {
		max-width: 640px;
		margin: 0 auto 10px;
		font-size: 0.72rem;
		line-height: 1.7;
		color: var(--muted);
	}
	.footer-r18 a {
		color: var(--accent);
	}
	.copyright {
		margin: 14px 0 0;
		font-size: 0.72rem;
		color: var(--muted);
	}
</style>
