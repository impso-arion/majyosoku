---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import DanbooruTrend from '../components/DanbooruTrend.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import XReply from '../components/XReply.astro';
import { CATEGORIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category,
	tags,
	dlsite_id,
	dlsite_url,
	danbooru_tags,
	prompt,
	images,
	models,
} = Astro.props;
const cat = CATEGORIES.find((c) => c.slug === category);
const showTrend =
	Boolean(dlsite_id || dlsite_url) ||
	(danbooru_tags?.length ?? 0) > 0 ||
	Boolean(prompt) ||
	(images?.length ?? 0) > 0 ||
	Boolean(models?.name);
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>

	<body>
		<Header />
		<div class="wrap">
			<div class="site-layout">
				<Sidebar />
				<main class="col-main">
					<article class="panel article">
						<div class="article-head">
							{
								cat && (
									<a class="cat-tag" href={`/categories/${cat.slug}/`}>
										{cat.emoji} {cat.label}
									</a>
								)
							}
							<h1 class="article-title">{title}</h1>
							<div class="post-meta">
								<span>🗓 <FormattedDate date={pubDate} /></span>
								{
									updatedDate && (
										<span>
											✏️ 更新 <FormattedDate date={updatedDate} />
										</span>
									)
								}
							</div>
						</div>

						{
							heroImage && (
								<div class="hero-image">
									<Image width={1020} height={510} src={heroImage} alt="" />
								</div>
							)
						}

						<div class="prose article-body">
							<slot />
							{
								showTrend && (
									<DanbooruTrend
										dlsiteId={dlsite_id}
										dlsiteUrl={dlsite_url}
										danbooruTags={danbooru_tags}
										prompt={prompt}
										images={images}
										models={models}
										title={title}
									/>
								)
							}
						</div>

						{
							tags && tags.length > 0 && (
								<div class="tag-row">
									{tags.map((t) => (
										<a class="tag-chip" href={`/tags/${encodeURIComponent(t)}/`}>
											#{t}
										</a>
									))}
								</div>
							)
						}

						<XReply title={title} />

						<div class="back-row">
							<a class="readmore" href="/blog">« 記事一覧に戻る</a>
						</div>
					</article>
				</main>
			</div>
		</div>
		<Footer />
	</body>
</html>

<style>
	.article {
		padding: 0;
	}
	.article-head {
		padding: 22px 22px 16px;
		border-bottom: 1px solid var(--border);
		background: var(--surface-2);
	}
	.article-head .cat-tag {
		display: inline-block;
		font-size: 0.74rem;
		font-weight: 700;
		color: var(--accent);
		border: 1px solid var(--accent-dim);
		border-radius: 4px;
		padding: 3px 12px;
		margin-bottom: 10px;
	}
	.article-head .cat-tag:hover {
		color: var(--text-strong);
		background: var(--accent-dim);
		text-decoration: none;
	}
	.article-title {
		font-size: 1.7rem;
		font-weight: 800;
		line-height: 1.4;
		margin: 0 0 10px;
	}
	.hero-image {
		padding: 18px 22px 0;
	}
	.hero-image :global(img) {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 10px;
		box-shadow: var(--box-shadow);
	}
	.article-body {
		padding: 20px 22px 8px;
	}
	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		padding: 0 22px 8px;
	}
	.back-row {
		padding: 0 22px 24px;
	}
	:global(.article .xreply) {
		margin-left: 22px;
		margin-right: 22px;
	}

	@media (max-width: 720px) {
		.article-title {
			font-size: 1.35rem;
		}
	}
</style>
