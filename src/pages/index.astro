---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Headline from '../components/Headline.astro';
import Sidebar from '../components/Sidebar.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const catInfo = (slug?: string) => CATEGORIES.find((c) => c.slug === slug);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="wrap">
			<div class="site-layout">
				<Sidebar />
				<main class="col-main">
					<Headline />

					<div class="section-bar"><span>🆕</span>最新記事</div>
					<ul class="post-list">
						{
							posts.map((post) => {
								const cat = catInfo(post.data.category);
								return (
									<li>
										<article class="post-card">
											{cat && (
												<span class="cat-tag">
													{cat.emoji} {cat.label}
												</span>
											)}
											<h2 class="post-title">
												<a href={`/blog/${post.id}/`}>{post.data.title}</a>
											</h2>
											<div class="post-meta">
												<span>🗓 <FormattedDate date={post.data.pubDate} /></span>
											</div>
											<p class="post-excerpt">{post.data.description}</p>
											{post.data.tags && post.data.tags.length > 0 && (
												<div class="card-tags">
													{post.data.tags.map((t) => (
														<a
															class="tag-chip"
															href={`/tags/${encodeURIComponent(t)}/`}
														>
															#{t}
														</a>
													))}
												</div>
											)}
											<a class="readmore" href={`/blog/${post.id}/`}>
												続きを読む »
											</a>
										</article>
									</li>
								);
							})
						}
						{
							posts.length === 0 && (
								<li>
									<article class="post-card">
										<p>まだ記事がないわ…今夜の黒ミサ用に焚べておくから待ってなさい。</p>
									</article>
								</li>
							)
						}
					</ul>
				</main>
			</div>
		</div>
		<Footer />
	</body>
</html>
