---
import { Image } from 'astro:assets';
import charaIcon from '../assets/brand/chara.webp';
import BaseHead from '../components/BaseHead.astro';
import CharacterSpeech from '../components/CharacterSpeech.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import BlueskyReply from '../components/BlueskyReply.astro';
import {
	AUTHOR_BIO,
	AUTHOR_NAME,
	AUTHOR_TITLE,
	BSKY_HANDLE,
	BSKY_URL,
	SITE_CATCH,
	SITE_DESCRIPTION,
	SITE_TITLE,
} from '../consts';

const pageTitle = `運営者情報 | ${SITE_TITLE}`;
const pageDesc = `${SITE_TITLE}の管理人・${AUTHOR_NAME}のプロフィールと運営方針、免責事項、お問い合わせについて。`;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={pageTitle} description={pageDesc} />
	</head>
	<body>
		<Header />
		<div class="wrap">
			<div class="site-layout">
				<Sidebar />
				<main class="col-main">
					<div class="section-bar">運営者情報</div>

					<article class="panel about">
						<div class="about-hero">
							<Image
								class="about-avatar"
								src={charaIcon}
								alt={AUTHOR_NAME}
								width={200}
								height={200}
								densities={[1, 2]}
							/>
							<div class="about-hero-text">
								<p class="about-catch">{SITE_CATCH}</p>
								<h1 class="about-name">{AUTHOR_NAME}</h1>
								<p class="about-title">{AUTHOR_TITLE}</p>
								<p class="about-bio">{AUTHOR_BIO}</p>
								<a class="about-bsky" href={BSKY_URL} target="_blank" rel="noopener">
									Bluesky {BSKY_HANDLE} をフォロー
								</a>
							</div>
						</div>

						<div class="prose about-body">
							<CharacterSpeech character="rina">
								ようこそ、私の結界へ。<strong>{AUTHOR_NAME}</strong>よ。AI画像生成とエロの狭間を彷徨う、へっぽこ見習い魔女。海外スレの熱量も、2ちゃんまとめみたいに読みやすく焼き直して焚べていくわ。今夜も黒ミサのために記事を用意しているの。
							</CharacterSpeech>

							<h2>このサイトについて</h2>
							<p>
								<strong>{SITE_TITLE}</strong>は、かつて流行した「まとめ速報」系ブログのノリで、
								<strong>{SITE_CATCH}</strong>という切り口の話題をお届けするサイトよ。堅苦しい技術解説やニュースを、私・リナが黒ミサ風に翻訳してあげる。
							</p>
							<p>
								海外板（Reddit）で気になったネタも扱うわ。長い英語原文をそのまま貼るんじゃなくて、
								<strong>論点だけ拾って2ちゃんまとめ風の会話調</strong>に焼き直し、最後は私が締める——そんな読みやすさ重視の紹介をするの。
							</p>
							<p>{SITE_DESCRIPTION}</p>

							<h2>何を発信するの？</h2>
							<ul class="about-topics">
								<li><a href="/categories/reddit">Redditまとめ</a></li>
								<li><a href="/categories">カテゴリ検索</a></li>
								<li><a href="/tags/Danbooru">Danbooruタグ</a></li>
								<li><a href="/models">モデル検索</a></li>
								<li><a href="/blog">記事一覧</a></li>
								<li><a href="/tags">タグ検索</a></li>
							</ul>
							<p>
								たとえば普通のメディアが「画像生成AIの学習データとタグ体系の関係」なんて言うところを、私はこう語るわ——「この作品、どんな Danbooru タグで組まれてるの？　モデルは Illustrious？　Pony？　今夜の供物として解剖してやるわ」ってね。
							</p>
							<p>
								Reddit側なら、「LTX が熱い」「webui-user.bat が落ちる」みたいなスレの空気を、レス番号つきのまとめ記事にして届けるわ。原文コピペ地獄にはしないから安心して。
							</p>
							<p>
								決済やクレカ規制の話は、基本的には扱わないわ。ここは<strong>生成の呪文とモデル、それから海外スレの熱量</strong>のための結界よ。
							</p>

							<h2>運営者情報</h2>
							<dl class="about-meta">
								<div>
									<dt>サイト名</dt>
									<dd>{SITE_TITLE}</dd>
								</div>
								<div>
									<dt>管理人</dt>
									<dd>{AUTHOR_NAME}（{AUTHOR_TITLE}）</dd>
								</div>
								<div>
									<dt>お問い合わせ</dt>
									<dd>
										<a href={BSKY_URL} target="_blank" rel="noopener">Bluesky {BSKY_HANDLE}</a>
										へのメンション・返信
									</dd>
								</div>
							</dl>

							<h2>免責事項</h2>
							<p>
								当サイトはアフィリエイト広告（成果報酬型広告）を利用しています。掲載する情報は執筆時点のものであり、正確性・最新性・有用性を保証するものではありません。当サイトの情報を利用して生じたいかなる損害についても、管理人は責任を負いかねます。
							</p>
							<p>
								Redditまとめ記事は、議論の構造・論点を会話調に再構成したものです。海外スレ原文の全訳・転載ではありません。
							</p>
							<p>
								当サイトは成人向けの話題を扱います。18歳未満の方の閲覧はご遠慮ください。
							</p>
						</div>

						<BlueskyReply />
					</article>
				</main>
			</div>
		</div>
		<Footer />
	</body>
</html>

<style>
	.about {
		padding: 0;
		overflow: hidden;
	}
	.about-hero {
		display: flex;
		gap: 20px;
		align-items: center;
		padding: 22px;
		background: var(--surface-2);
		border-bottom: 1px solid var(--border);
	}
	.about-avatar {
		width: 112px;
		height: 112px;
		border-radius: 50%;
		object-fit: cover;
		background: var(--icon-bg);
		border: 1px solid var(--border);
		flex-shrink: 0;
	}
	.about-catch {
		margin: 0 0 6px;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: var(--accent);
	}
	.about-name {
		margin: 0 0 4px;
		font-size: 1.6rem;
		font-weight: 800;
		color: var(--text-strong);
		line-height: 1.3;
	}
	.about-title {
		margin: 0 0 10px;
		font-size: 0.85rem;
		color: var(--muted);
	}
	.about-bio {
		margin: 0 0 14px;
		font-size: 0.9rem;
		line-height: 1.75;
		color: var(--text);
	}
	.about-bsky {
		display: inline-block;
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--text-strong);
		background: var(--accent-dim);
		border-radius: 6px;
		padding: 8px 16px;
	}
	.about-bsky:hover {
		background: var(--accent);
		text-decoration: none;
	}
	.about-body {
		padding: 8px 22px 8px;
	}
	.about-topics {
		list-style: none;
		margin: 0 0 1.2em;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}
	.about-topics a {
		display: inline-block;
		font-size: 0.82rem;
		font-weight: 700;
		color: var(--accent);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 4px 12px;
		background: var(--surface-2);
		text-decoration: none;
	}
	.about-topics a:hover {
		border-color: var(--accent);
		color: var(--text-strong);
	}
	.about-meta {
		margin: 0 0 1.4em;
		padding: 0;
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
		background: var(--surface-2);
	}
	.about-meta > div {
		display: grid;
		grid-template-columns: 7.5em 1fr;
		gap: 12px;
		padding: 12px 14px;
		border-bottom: 1px solid var(--border);
	}
	.about-meta > div:last-child {
		border-bottom: none;
	}
	.about-meta dt {
		margin: 0;
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--muted);
	}
	.about-meta dd {
		margin: 0;
		font-size: 0.9rem;
		color: var(--text);
	}
	:global(.about .xreply) {
		margin: 8px 22px 22px;
	}

	@media (max-width: 720px) {
		.about-hero {
			flex-direction: column;
			text-align: center;
		}
		.about-meta > div {
			grid-template-columns: 1fr;
			gap: 4px;
		}
		.about-topics {
			justify-content: center;
		}
	}
</style>
