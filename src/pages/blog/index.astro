---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import Sidebar from '../../components/Sidebar.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const catInfo = (slug?: string) => CATEGORIES.find((c) => c.slug === slug);
const pageTitle = `記事一覧 | ${SITE_TITLE}`;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={pageTitle} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="wrap">
			<div class="site-layout">
				<Sidebar />
				<main class="col-main">
					<div class="section-bar"><span>📚</span>記事一覧</div>

					<div class="cat-filter" role="navigation" aria-label="カテゴリで絞り込み">
						<span class="filter-btn active">すべて</span>
						{
							CATEGORIES.map((c) => (
								<a class="filter-btn" href={`/categories/${c.slug}/`}>
									{c.emoji} {c.label}
								</a>
							))
						}
						<a class="filter-all-cats" href="/categories">カテゴリ検索 »</a>
					</div>

					<ul class="post-list">
						{
							posts.map((post) => {
								const cat = catInfo(post.data.category);
								return (
									<li>
										<article class="post-card">
											{cat && (
												<a class="cat-tag" href={`/categories/${cat.slug}/`}>
													{cat.emoji} {cat.label}
												</a>
											)}
											<h2 class="post-title">
												<a href={`/blog/${post.id}/`}>{post.data.title}</a>
											</h2>
											<div class="post-meta">
												<span>🗓 <FormattedDate date={post.data.pubDate} /></span>
											</div>
											<p class="post-excerpt">{post.data.description}</p>
											{post.data.tags && post.data.tags.length > 0 && (
												<div class="card-tags">
													{post.data.tags.map((t) => (
														<a
															class="tag-chip"
															href={`/tags/${encodeURIComponent(t)}/`}
														>
															#{t}
														</a>
													))}
												</div>
											)}
											<a class="readmore" href={`/blog/${post.id}/`}>
												続きを読む »
											</a>
										</article>
									</li>
								);
							})
						}
					</ul>
				</main>
			</div>
		</div>
		<Footer />

		<style>
			.cat-filter {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 8px;
				margin-bottom: 18px;
			}
			.filter-btn {
				display: inline-block;
				font-family: inherit;
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--accent);
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 999px;
				padding: 6px 14px;
				text-decoration: none;
				transition: all 0.15s ease;
			}
			a.filter-btn:hover {
				border-color: var(--accent);
				background: var(--surface-2);
				text-decoration: none;
			}
			.filter-btn.active {
				color: var(--text-strong);
				background: var(--accent-dim);
				border-color: transparent;
			}
			.filter-all-cats {
				margin-left: auto;
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--muted);
			}
			.filter-all-cats:hover {
				color: var(--accent);
			}
		</style>
	</body>
</html>
