---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Sidebar from '../../components/Sidebar.astro';
import { SITE_TITLE } from '../../consts';
import { getTagCounts } from '../../lib/posts';

const tags = await getTagCounts();
const pageTitle = `タグ検索 | ${SITE_TITLE}`;
const total = tags.length;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={pageTitle}
			description={`${SITE_TITLE}の全タグ一覧。キーワードで魔女の記事タグを検索できるわ。`}
		/>
	</head>
	<body>
		<Header />
		<div class="wrap">
			<div class="site-layout">
				<Sidebar />
				<main class="col-main">
					<div class="section-bar"><span>🔖</span>タグ検索</div>

					<div class="panel">
						<div class="panel-body">
							<label class="search-field">
								<span class="sr-only">タグを検索</span>
								<input
									id="tag-search"
									type="search"
									placeholder="タグを入力して絞り込む（例：規制 / FANZA）"
									autocomplete="off"
								/>
							</label>
							<p class="tag-count">
								全 <strong id="visible-count">{total}</strong> 個のタグ
							</p>

							<ul class="tag-cloud" id="tag-cloud">
								{
									tags.map((t) => (
										<li class="tag-item" data-tag={t.tag.toLowerCase()}>
											<a
												class="tag-chip"
												href={`/tags/${encodeURIComponent(t.tag)}/`}
											>
												#{t.tag} <span class="cnt">({t.count})</span>
											</a>
										</li>
									))
								}
							</ul>
							{
								total === 0 && (
									<p class="empty">まだタグの付いた記事が無いわ…</p>
								)
							}
							<p class="no-hit" id="no-hit" hidden>
								そのキーワードのタグは見つからないわ…
							</p>
						</div>
					</div>
				</main>
			</div>
		</div>
		<Footer />

		<script>
			const input =
				document.getElementById('tag-search') as HTMLInputElement | null;
			const items = Array.from(
				document.querySelectorAll<HTMLElement>('.tag-item'),
			);
			const visibleCount = document.getElementById('visible-count');
			const noHit = document.getElementById('no-hit');

			function normalize(s: string) {
				return s.trim().toLowerCase();
			}

			function filter() {
				const q = normalize(input?.value ?? '');
				let hits = 0;
				for (const item of items) {
					const tag = item.dataset.tag ?? '';
					const match = q === '' || tag.includes(q);
					item.hidden = !match;
					if (match) hits++;
				}
				if (visibleCount) visibleCount.textContent = String(hits);
				if (noHit) noHit.hidden = hits !== 0;
			}

			input?.addEventListener('input', filter);
		</script>

		<style>
			.search-field input {
				width: 100%;
				font-size: 1rem;
				padding: 12px 14px;
				color: var(--text-strong);
				background: var(--bg);
				border: 1px solid var(--border);
				border-radius: 8px;
				outline: none;
			}
			.search-field input:focus {
				border-color: var(--accent);
			}
			.search-field input::placeholder {
				color: var(--muted);
			}
			.tag-count {
				margin: 12px 0;
				font-size: 0.82rem;
				color: var(--muted);
			}
			.tag-count strong {
				color: var(--text-strong);
			}
			.tag-cloud {
				display: flex;
				flex-wrap: wrap;
				gap: 10px;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.tag-cloud .tag-chip {
				font-size: 0.9rem;
				padding: 6px 14px;
			}
			.no-hit,
			.empty {
				color: var(--muted);
				padding: 16px 0;
			}
		</style>
	</body>
</html>
