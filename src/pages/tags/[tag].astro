---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import Sidebar from '../../components/Sidebar.astro';
import { CATEGORIES, SITE_TITLE } from '../../consts';
import { getTagCounts, getPostsByTag } from '../../lib/posts';

export async function getStaticPaths() {
	const tags = await getTagCounts();
	return Promise.all(
		tags.map(async ({ tag }) => ({
			params: { tag },
			props: { tag, posts: await getPostsByTag(tag) },
		})),
	);
}

const { tag, posts } = Astro.props;
const catInfo = (slug?: string) => CATEGORIES.find((c) => c.slug === slug);
const pageTitle = `#${tag} の記事 | ${SITE_TITLE}`;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={pageTitle}
			description={`「${tag}」タグが付いた${SITE_TITLE}の記事一覧。`}
		/>
	</head>
	<body>
		<Header />
		<div class="wrap">
			<div class="site-layout">
				<Sidebar />
				<main class="col-main">
					<div class="section-bar">
						<span>🔖</span>タグ： #{tag}（{posts.length}件）
					</div>
					<p class="back-tags"><a href="/tags">« タグ検索に戻る</a></p>

					<ul class="post-list">
						{
							posts.map((post) => {
								const cat = catInfo(post.data.category);
								return (
									<li>
										<article class="post-card">
											{cat && (
												<span class="cat-tag">
													{cat.emoji} {cat.label}
												</span>
											)}
											<h2 class="post-title">
												<a href={`/blog/${post.id}/`}>{post.data.title}</a>
											</h2>
											<div class="post-meta">
												<span>🗓 <FormattedDate date={post.data.pubDate} /></span>
											</div>
											<p class="post-excerpt">{post.data.description}</p>
											{post.data.tags && post.data.tags.length > 0 && (
												<div class="card-tags">
													{post.data.tags.map((t) => (
														<a
															class="tag-chip"
															href={`/tags/${encodeURIComponent(t)}/`}
														>
															#{t}
														</a>
													))}
												</div>
											)}
											<a class="readmore" href={`/blog/${post.id}/`}>
												続きを読む »
											</a>
										</article>
									</li>
								);
							})
						}
					</ul>
				</main>
			</div>
		</div>
		<Footer />

		<style>
			.back-tags {
				margin: -6px 0 16px;
				font-size: 0.85rem;
			}
		</style>
	</body>
</html>
